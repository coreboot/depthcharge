CONFIG_VARIANT_NAME="ocelot"
CONFIG_EC_VBOOT_SUPPORT=y
CONFIG_DRIVER_GPIO_WILDCATLAKE=y
CONFIG_DRIVER_SOUND_RT721_SNDW=y
CONFIG_DRIVER_BUS_I2S_INTEL_COMMON_MAX98357A=y
CONFIG_DRIVER_SOUND_MAX98363_SNDW=y

# For Ocelot RVP SKU1 (RTK PDC)
CONFIG_DRIVER_EC_RTS5453=y
CONFIG_DRIVER_EC_RTS545X_VID=0x18d1
CONFIG_DRIVER_EC_RTS545X_PID=0x5075
