# Arch
CONFIG_ARCH_X86=y
CONFIG_ARCH_X86_64=y

# Board
CONFIG_BOARD_DIR="atria"

# Image
CONFIG_HEAP_SIZE=0x04000000

# Vboot
CONFIG_ANDROID_PVMFW=y
CONFIG_BOOTCONFIG=y
CONFIG_CROSSYSTEM_ACPI=y
CONFIG_EC_SLOW_UPDATE=y
CONFIG_EC_VBOOT_SUPPORT=y

# Kernel format
CONFIG_KERNEL_MULTIBOOT=y
CONFIG_KERNEL_MULTIBOOT_ZBI=y
CONFIG_KERNEL_ZIMAGE=y

# Drivers
CONFIG_DRIVER_AHCI=y
CONFIG_DRIVER_BUS_I2C_CROS_EC_TUNNEL=y
CONFIG_DRIVER_BUS_I2C_DESIGNWARE=y
CONFIG_DRIVER_BUS_I2C_DESIGNWARE_PCI=y
CONFIG_DRIVER_EC_CROS=y
CONFIG_DRIVER_EC_CROS_LPC=y
CONFIG_DRIVER_EC_CROS_DELAY_AFTER_EC_REBOOT_MS=250
CONFIG_DRIVER_FLASH_MEMMAPPED=y
CONFIG_DRIVER_INPUT_MKBP=y
CONFIG_DRIVER_INPUT_MKBP_KEYMATRIX_STANDARD_V10=y
CONFIG_DRIVER_INPUT_PS2=y
CONFIG_DRIVER_POWER_PCH=y
CONFIG_DRIVER_SOC_NOVALAKE=y
CONFIG_DRIVER_TPM_GOOGLE_TI50=y
CONFIG_DRIVER_TPM_I2C=y

# Storage
CONFIG_DRIVER_STORAGE_SDHCI_PCI=y
CONFIG_DRIVER_SDHCI=y
CONFIG_DRIVER_STORAGE_MMC=y
CONFIG_DRIVER_STORAGE_UFS_INTEL=y
CONFIG_DRIVER_STORAGE_NVME=y
CONFIG_DRIVER_STORAGE_COMMON=y

# Audio
# CONFIG_DRIVER_BUS_I2S_INTEL_COMMON_I2S is not set
# CONFIG_DRIVER_BUS_SOUNDWIRE is not set
# CONFIG_DRIVER_INTEL_GENERIC_AUDIO is not set
# CONFIG_DRIVER_SOUND_GPIO_AMP is not set
# CONFIG_DRIVER_SOUND_HDA is not set
# CONFIG_DRIVER_SOUND_I2S is not set
# CONFIG_DRIVER_SOUND_ROUTE is not set

# Aux FW
# CONFIG_AUXFW_SOFTWARE_SYNC is not set
# CONFIG_CROS_EC_PROBE_AUX_FW_INFO is not set

# USB Type-C
CONFIG_INTEL_TCSS_USE_PDC_PMC_MUX_CONFIG=y

# Intel CSE
CONFIG_DRIVER_FLASH_FAST_SPI=y
# CONFIG_DRIVER_SOC_INTEL_CSE is not set
# CONFIG_SOC_INTEL_COMMON_BLOCK_ME_SPEC_21 is not set
# CONFIG_SOC_INTEL_CSE_FW_PARTITION_CMOS_OFFSET is not set
# CONFIG_SOC_INTEL_CSE_HECI1_DISABLE_USING_PMC_IPC is not set
# CONFIG_SOC_INTEL_CSE_LITE_PSR is not set
# CONFIG_SOC_INTEL_CSE_LITE_SKU is not set
# CONFIG_SOC_INTEL_CSE_LITE_SYNC_BY_PAYLOAD is not set
# CONFIG_SOC_INTEL_CSE_SEND_EOP_BY_PAYLOAD is not set
# CONFIG_SOC_INTEL_CSE_PRE_CPU_RESET_TELEMETRY_V3 is not set
# CONFIG_SOC_INTEL_HAS_ISH_MAIN_FW is not set
# CONFIG_SOC_INTEL_CSE_RW_UPDATE is not set
CONFIG_MAX_HECI_DEVICES=3
